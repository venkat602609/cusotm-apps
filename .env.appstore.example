# Copy this file to .env.appstore and fill in values from App Store Connect.
# Do not commit .env.appstore or your .p8 private key.

APP_STORE_CONNECT_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_ISSUER_ID=YOUR_ISSUER_ID
APP_STORE_CONNECT_KEY_PATH=/absolute/path/to/AuthKey_YOUR_KEY_ID.p8

# Required by App Store Connect for App Review contact info.
# This is private to Apple review and is not published on the App Store.
APP_REVIEW_PHONE=+1 555 555 5555

# Optional. This is useful if your Apple account belongs to multiple teams.
# FASTLANE_TEAM_ID=48CHNBCQTS
