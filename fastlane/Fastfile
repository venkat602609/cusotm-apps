default_platform(:ios)

platform :ios do
  desc "Upload OrbitKit metadata and screenshots to App Store Connect"
  lane :upload_appstore_metadata do
    require "fileutils"

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_KEY_PATH")
    )

    metadata_source = File.expand_path("metadata", __dir__)
    generated_metadata = File.expand_path("generated_metadata", __dir__)
    FileUtils.rm_rf(generated_metadata)
    FileUtils.cp_r(metadata_source, generated_metadata)

    if ENV["APP_REVIEW_PHONE"].to_s.strip.empty?
      UI.user_error!("APP_REVIEW_PHONE is required. Add it to .env.appstore in international format, for example +1 555 555 5555.")
    end

    File.write(
      File.join(generated_metadata, "review_information", "phone_number.txt"),
      "#{ENV.fetch("APP_REVIEW_PHONE").strip}\n"
    )

    screenshots_root = File.expand_path("../PersonalTools/AppStoreAssets/Screenshots/AppStore", __dir__)
    fastlane_screenshots = File.expand_path("screenshots/en-US", __dir__)
    FileUtils.rm_rf(fastlane_screenshots)
    FileUtils.mkdir_p(fastlane_screenshots)

    screenshot_sources = {
      "iPhone-6.5" => "iphone",
      "iPad-13" => "ipad"
    }

    screenshot_sources.each do |folder, prefix|
      Dir[File.join(screenshots_root, folder, "*.png")].sort.each_with_index do |source, index|
        FileUtils.cp(source, File.join(fastlane_screenshots, "#{prefix}-#{index + 1}-#{File.basename(source)}"))
      end
    end

    deliver(
      api_key: api_key,
      app_identifier: "com.venkata.Orbit",
      metadata_path: "fastlane/generated_metadata",
      screenshots_path: "fastlane/screenshots",
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_binary_upload: true,
      skip_app_version_update: true,
      overwrite_screenshots: true
    )
  end
end
